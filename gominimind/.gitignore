# GoMiniMind .gitignore
# 编译输出
*.exe
*.exe~
*.dll
*.so
*.dylib

# 测试二进制文件
*.test

# 覆盖率输出
*.out
coverage.html
coverage.txt
*.cover

# 依赖目录
vendor/

# 构建输出
dist/
build/
bin/
release/

# IDE配置
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 操作系统文件
Thumbs.db
.desktop.ini

# 日志文件
*.log
logs/

# 数据文件
data/
*.db
*.db-journal
*.db-shm
*.db-wal

# 模型文件
models/*.pth
models/*.pt
models/*.bin
models/*.safetensors
models/*.onnx
models/*.trt
models/*.tflite
checkpoints/

# 环境配置文件
.env
.env.local
.env.*.local

# 证书文件
*.pem
*.key
*.crt
*.csr
*.srl

# 临时文件
tmp/
temp/
*.tmp
*.temp

# 缓存目录
.cache/
.golangci-cache/

# Air热重载
tmp/

# Docker卷
docker-volumes/

# 性能分析文件
*.pprof
*.prof
cpu.prof
mem.prof
block.prof
goroutine.prof
threadcreate.prof
trace.out

# mock生成文件
mocks/

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# 文档生成
docs/_build/
site/

# 压缩文件
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# 其他
*.bak
*.backup
*.old
.history/