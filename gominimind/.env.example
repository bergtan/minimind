# MiniMind Go API Server Environment Configuration
# Copy this file to .env and modify values as needed

# =============================================================================
# Application Configuration
# =============================================================================

# Server Configuration
PORT=8000
HOST=0.0.0.0
GIN_MODE=release
LOG_LEVEL=info
CONFIG_PATH=./configs/default.yaml

# API Security
API_KEY=your_minimind_api_key_here
API_KEY_REQUIRED=true
ALLOWED_IPS=127.0.0.1,192.168.1.0/24
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Model Configuration
MODEL_PATH=./models/minimind
MODEL_NAME=minimind
MODEL_VERSION=2.0
CONTEXT_LENGTH=32768
MAX_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL Database
DATABASE_URL=postgres://minimind:password@localhost:5432/minimind?sslmode=disable
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=minimind
POSTGRES_USER=minimind
POSTGRES_PASSWORD=postgres_password
POSTGRES_SSL_MODE=disable
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_MAX_IDLE_CONNS=10
POSTGRES_MAX_LIFETIME=1h

# =============================================================================
# Cache Configuration
# =============================================================================

# Redis Cache
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_MAX_RETRIES=3
REDIS_TIMEOUT=10s

# Memory Cache
MEMORY_CACHE_ENABLED=true
MEMORY_CACHE_SIZE=100MB
MEMORY_CACHE_TTL=10m

# =============================================================================
# Performance Configuration
# =============================================================================

# Concurrency Settings
MAX_CONCURRENT_REQUESTS=100
MAX_BATCH_SIZE=32
WORKER_POOL_SIZE=4
QUEUE_SIZE=1000

# Memory Management
MAX_MEMORY_USAGE=80%
GPU_MEMORY_LIMIT=90%
CPU_MEMORY_LIMIT=80%

# Response Caching
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL=5m
RESPONSE_CACHE_SIZE=500MB

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_PATH=/metrics
METRICS_COLLECTION_INTERVAL=30s

# Logging Configuration
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=./logs/minimind.log
LOG_MAX_SIZE=100MB
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s

# =============================================================================
# Security Configuration
# =============================================================================

# TLS/SSL Configuration
TLS_ENABLED=false
TLS_CERT_PATH=./ssl/cert.pem
TLS_KEY_PATH=./ssl/key.pem
TLS_MIN_VERSION=1.2

# CORS Configuration
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key
CORS_MAX_AGE=86400

# JWT Configuration (if applicable)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=24h
JWT_ISSUER=minimind-api

# =============================================================================
# External Services
# =============================================================================

# OpenAI API (for fallback or comparison)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=30s

# HuggingFace Hub
HF_TOKEN=your_huggingface_token_here
HF_CACHE_DIR=./cache/huggingface

# ModelScope
MODELSCOPE_TOKEN=your_modelscope_token_here
MODELSCOPE_CACHE_DIR=./cache/modelscope

# =============================================================================
# Deployment Configuration
# =============================================================================

# Docker Configuration
DOCKER_REGISTRY=registry.example.com
DOCKER_NAMESPACE=minimind
DOCKER_TAG=latest

# Kubernetes Configuration
K8S_NAMESPACE=minimind
K8S_REPLICAS=3
K8S_RESOURCE_LIMITS_MEMORY=2Gi
K8S_RESOURCE_LIMITS_CPU=1
K8S_RESOURCE_REQUESTS_MEMORY=1Gi
K8S_RESOURCE_REQUESTS_CPU=0.5

# =============================================================================
# Development Configuration
# =============================================================================

# Debug Mode
DEBUG=false
PROFILE_ENABLED=false
PROFILE_PORT=6060

# Development Database
DEV_DATABASE_URL=postgres://minimind:password@localhost:5432/minimind_dev?sslmode=disable
DEV_REDIS_URL=redis://localhost:6379/1

# Test Configuration
TEST_DATABASE_URL=postgres://minimind:password@localhost:5432/minimind_test?sslmode=disable
TEST_REDIS_URL=redis://localhost:6379/2
TEST_TIMEOUT=30s

# =============================================================================
# Feature Flags
# =============================================================================

# Feature Toggles
FEATURE_STREAMING_ENABLED=true
FEATURE_BATCH_PROCESSING_ENABLED=true
FEATURE_EMBEDDINGS_ENABLED=true
FEATURE_FILE_UPLOAD_ENABLED=true
FEATURE_MODEL_MANAGEMENT_ENABLED=true
FEATURE_MONITORING_ENABLED=true
FEATURE_CACHING_ENABLED=true

# Experimental Features
EXPERIMENTAL_QUANTIZATION_ENABLED=false
EXPERIMENTAL_DISTRIBUTED_INFERENCE=false
EXPERIMENTAL_GPU_ACCELERATION=false

# =============================================================================
# Service URLs
# =============================================================================

# Internal Services
REDIS_SERVICE_URL=redis://redis:6379
POSTGRES_SERVICE_URL=postgres://postgres:5432
PROMETHEUS_SERVICE_URL=http://prometheus:9090
GRAFANA_SERVICE_URL=http://grafana:3000

# External Services
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=minimind-models

# =============================================================================
# Environment Specific Overrides
# =============================================================================

# Development Environment Overrides
if [ "$ENVIRONMENT" = "development" ]; then
    LOG_LEVEL=debug
    DEBUG=true
    API_KEY_REQUIRED=false
    CORS_ALLOWED_ORIGINS=*
fi

# Staging Environment Overrides
if [ "$ENVIRONMENT" = "staging" ]; then
    LOG_LEVEL=info
    DEBUG=false
    API_KEY_REQUIRED=true
    CORS_ALLOWED_ORIGINS=https://staging.minimind.com
fi

# Production Environment Overrides
if [ "$ENVIRONMENT" = "production" ]; then
    LOG_LEVEL=warn
    DEBUG=false
    API_KEY_REQUIRED=true
    CORS_ALLOWED_ORIGINS=https://minimind.com
    TLS_ENABLED=true
fi

# =============================================================================
# Notes
# =============================================================================

# Important Security Notes:
# 1. Change all default passwords before deploying to production
# 2. Use strong, unique API keys
# 3. Enable TLS/SSL in production
# 4. Configure proper CORS settings
# 5. Set appropriate rate limits

# Performance Notes:
# 1. Adjust memory limits based on available resources
# 2. Configure connection pools appropriately
# 3. Monitor cache hit rates and adjust TTL
# 4. Set appropriate batch sizes for your workload

# Deployment Notes:
# 1. Use environment-specific configurations
# 2. Set up proper monitoring and alerting
# 3. Configure backup strategies for databases
# 4. Plan for scaling and load balancing